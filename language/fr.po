msgstr "Serveur Iiif : enregistrer les dimensions des médias"

#: Module.php:682
msgid "Iiif Server: Upgrade old tables of contents to new format with four columns (to do only one time for old external manifests)"
msgstr "Serveur Iiif : conversion des anciennes tables des matières au nouveau format à quatre colonnes (à effectuer une seule fois pour les anciens manifestes externes)"

#: Module.php:689
msgid "Options to cache manifests"
msgstr "Options pour mettre les manifestes en cache"

#: Module.php:700
